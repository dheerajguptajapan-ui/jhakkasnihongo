{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and overall progress",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "level": { "type": "number" },
        "xp": { "type": "number" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "level", "xp"]
    },
    "Item": {
      "title": "Item",
      "description": "A radical, kanji, or vocabulary item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["radical", "kanji", "vocabulary"] },
        "character": { "type": "string" },
        "meanings": { "type": "array", "items": { "type": "string" } },
        "readings": { "type": "array", "items": { "type": "string" } },
        "level": { "type": "number" },
        "mnemonic": { "type": "string" },
        "radical": { "type": "string" },
        "sentences": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "japanese": { "type": "string" },
              "english": { "type": "string" },
              "furigana": { "type": "string" }
            }
          }
        },
        "combinations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "word": { "type": "string" },
              "reading": { "type": "string" },
              "meaning": { "type": "string" }
            }
          }
        },
        "dayToDayUses": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "type", "character", "level"]
    },
    "UserItem": {
      "title": "UserItem",
      "description": "User's progress on a specific item",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "itemId": { "type": "string" },
        "srsStage": { "type": "number" },
        "nextReviewAt": { "type": "string", "format": "date-time" },
        "lastReviewedAt": { "type": "string", "format": "date-time" },
        "streak": { "type": "number" }
      },
      "required": ["uid", "itemId", "srsStage"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/items/{itemId}": {
      "schema": "Item",
      "description": "Global items database"
    },
    "/users/{userId}/userItems/{userItemId}": {
      "schema": "UserItem",
      "description": "User-specific progress on items"
    }
  }
}
